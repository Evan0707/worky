# ══════════════════════════════════════════════
# ChantierPro — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# Ne committez JAMAIS .env.local dans Git
# ══════════════════════════════════════════════

# ── Application ──────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=your-random-secret-here  # génerer avec: openssl rand -base64 32

# ── Base de données (Neon PostgreSQL) ────────
# Créer votre projet sur https://neon.tech (région EU-West Frankfurt)
# Pooled URL (port 6543) — utilisée par Prisma à runtime
DATABASE_URL=postgresql://user:password@host.neon.tech:6543/chantierpro?sslmode=require&pgbouncer=true
# Unpooled URL (port 5432) — utilisée pour les migrations
DATABASE_URL_UNPOOLED=postgresql://user:password@host.neon.tech:5432/chantierpro?sslmode=require

# ── NextAuth v5 (Auth.js) ────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Resend (Email OTP) — https://resend.com/api-keys
AUTH_RESEND_KEY=re_...
AUTH_EMAIL_FROM=noreply@chantierpro.fr

# ── UploadThing ──────────────────────────────
# https://uploadthing.com/dashboard
UPLOADTHING_SECRET=sk_live_...
UPLOADTHING_APP_ID=your-app-id

# ── Resend (emails transactionnels) ──────────
RESEND_API_KEY=re_...

# ── Stripe ───────────────────────────────────
# https://dashboard.stripe.com/apikeys (mode TEST)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...  # obtenu avec: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_PRICE_ID_PRO=price_...    # ID du prix PRO 15€/mois créé dans Stripe

# ── Pusher (temps réel) ───────────────────────
# https://pusher.com/dashboard (cluster EU)
PUSHER_APP_ID=your-app-id
PUSHER_SECRET=your-pusher-secret
NEXT_PUBLIC_PUSHER_KEY=your-pusher-key
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# ── Sentry (monitoring) ───────────────────────
# https://sentry.io
SENTRY_DSN=https://...@sentry.io/...

# ── Admin ────────────────────────────────────
ADMIN_SECRET=your-admin-secret
