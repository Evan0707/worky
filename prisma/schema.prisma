// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ==============================
// NextAuth Tables
// ==============================

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==============================
// Application Models
// ==============================

enum Plan {
  FREE
  PRO
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  plan                 Plan      @default(FREE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  // Artisan profile
  companyName          String?
  siret                String?
  companyAddress       String?
  logoUrl              String?
  logoKey              String?
  hourlyRate           Decimal?  @db.Decimal(10, 2)
  vatRate              Decimal?  @db.Decimal(5, 2) // e.g. 20.0
  iban                 String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  projects Project[]
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  DONE
}

model Project {
  id              String        @id @default(cuid())
  name            String
  address         String
  status          ProjectStatus @default(ACTIVE)
  clientName      String
  clientPhone     String?
  clientEmail     String?
  description     String?       @db.Text
  startDate       DateTime?
  endDate         DateTime?
  shareToken      String        @unique @default(uuid())
  shareExpiresAt  DateTime?
  artisanId       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  artisan       User           @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  photos        Photo[]
  timeEntries   TimeEntry[]
  materials     Material[]
  invoices      Invoice[]
  clientActions ClientAction[]

  @@index([artisanId])
  @@index([shareToken])
}

model Photo {
  id        String   @id @default(cuid())
  projectId String
  url       String
  key       String   @unique // UploadThing file key
  note      String?  @db.Text
  lat       Float?
  lng       Float?
  takenAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  projectId   String
  date        DateTime @db.Date
  hours       Decimal  @db.Decimal(4, 2)
  description String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Material {
  id        String  @id @default(cuid())
  projectId String
  label     String
  quantity  Decimal @db.Decimal(10, 3)
  unitPrice Decimal @db.Decimal(10, 2)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum InvoiceType {
  QUOTE
  INVOICE
}

enum InvoiceStatus {
  DRAFT
  SENT
  ACCEPTED
  REFUSED
  PAID
  OVERDUE
}

model Invoice {
  id              String        @id @default(cuid())
  projectId       String
  number          String        @unique
  type            InvoiceType
  status          InvoiceStatus @default(DRAFT)
  lines           Json
  totalHT         Decimal       @db.Decimal(10, 2)
  totalTVA        Decimal       @db.Decimal(10, 2)
  totalTTC        Decimal       @db.Decimal(10, 2)
  issuedAt        DateTime?
  dueAt           DateTime?
  paidAt          DateTime?
  facturXPath     String?
  remindersSentAt DateTime[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum ClientActionType {
  STEP_VALIDATED
  COMMENT
  SIGNATURE
}

model ClientAction {
  id        String           @id @default(cuid())
  projectId String
  type      ClientActionType
  payload   Json?
  createdAt DateTime         @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
