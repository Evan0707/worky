generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                   String      @id @default(cuid())
  name                 String?
  email                String?     @unique
  emailVerified        DateTime?
  image                String?
  plan                 Plan        @default(FREE)
  stripeCustomerId     String?     @unique
  stripeSubscriptionId String?     @unique
  locale               String      @default("fr-FR")
  country              String      @default("FR")
  currency             String      @default("EUR")
  vatScheme            VatScheme   @default(STANDARD)
  vatNumber            String?
  siret                String?
  steuernummer         String?
  bceNumber            String?
  companyName          String?
  companyAddress       String?
  logoUrl              String?
  logoKey              String?
  hourlyRate           Decimal?    @db.Decimal(10, 2)
  iban                 String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  proTrialUsed         Boolean     @default(false)
  industry             String?
  setupComplete        Boolean     @default(false)
  accounts             Account[]
  projects             Project[]
  sessions             Session[]
  ownedTeam            Team?       @relation("TeamOwner")
  teamMember           TeamMember?
}

model Team {
  id          String           @id @default(cuid())
  name        String
  ownerId     String           @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  owner       User             @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  invitations TeamInvitation[]
  members     TeamMember[]

  @@index([ownerId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String   @unique
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model TeamInvitation {
  id         String    @id @default(cuid())
  teamId     String
  email      String
  role       TeamRole  @default(MEMBER)
  token      String    @unique @default(uuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, email])
  @@index([teamId])
  @@index([token])
}

model Project {
  id                 String         @id @default(cuid())
  name               String
  address            String
  status             ProjectStatus  @default(ACTIVE)
  clientName         String
  clientPhone        String?
  clientEmail        String?
  clientLocale       String?
  description        String?
  startDate          DateTime?
  endDate            DateTime?
  shareToken         String         @unique @default(uuid())
  shareExpiresAt     DateTime?
  artisanId          String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  clientLastViewedAt DateTime?
  budget             Int?
  progress           Int            @default(0)
  nextSteps          Json?
  clientActions      ClientAction[]
  invoices           Invoice[]
  materials          Material[]
  photos             Photo[]
  artisan            User           @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  timeEntries        TimeEntry[]

  @@index([artisanId])
  @@index([shareToken])
}

model Photo {
  id        String   @id @default(cuid())
  projectId String
  url       String
  key       String   @unique
  note      String?
  lat       Float?
  lng       Float?
  takenAt   DateTime @default(now())
  order     Int      @default(0)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  projectId   String
  date        DateTime @db.Date
  hours       Decimal  @db.Decimal(4, 2)
  description String?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Material {
  id        String  @id @default(cuid())
  projectId String
  label     String
  quantity  Decimal @db.Decimal(10, 3)
  unitPrice Decimal @db.Decimal(10, 2)
  unit      String  @default("u")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Invoice {
  id              String        @id @default(cuid())
  projectId       String
  number          String        @unique
  type            InvoiceType
  status          InvoiceStatus @default(DRAFT)
  lines           Json
  totalHT         Int
  totalTVA        Int
  totalTTC        Int
  currency        String        @default("EUR")
  locale          String        @default("fr-FR")
  invoiceFormat   InvoiceFormat @default(STANDARD_PDF)
  issuedAt        DateTime?
  dueAt           DateTime?
  paidAt          DateTime?
  facturXPath     String?
  remindersSentAt DateTime[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, status])
}

model ClientAction {
  id        String           @id @default(cuid())
  projectId String
  type      ClientActionType
  payload   Json?
  createdAt DateTime         @default(now())
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum Plan {
  FREE
  PRO
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  DONE
  ARCHIVED
}

enum InvoiceType {
  QUOTE
  INVOICE
}

enum InvoiceStatus {
  DRAFT
  SENT
  ACCEPTED
  REFUSED
  PAID
  OVERDUE
}

/// Electronic invoicing format per country
enum InvoiceFormat {
  STANDARD_PDF
  FACTURX
  ZUGFERD
  PEPPOL
  FACTURAE
}

enum ClientActionType {
  STEP_VALIDATED
  COMMENT
  SIGNATURE
}

/// VAT scheme per country/status
enum VatScheme {
  STANDARD
  REDUCED
  MICRO_ENTREPRENEUR
  EXEMPT
  REVERSE_CHARGE
}
