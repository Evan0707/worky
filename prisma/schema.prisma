generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                   String      @id @default(cuid())
  name                 String?
  email                String?     @unique
  emailVerified        DateTime?
  image                String?
  plan                 Plan        @default(FREE)
  stripeCustomerId     String?     @unique
  stripeSubscriptionId String?     @unique
  locale               String      @default("fr-FR")
  country              String      @default("FR")
  currency             String      @default("EUR")
  vatScheme            VatScheme   @default(STANDARD)
  vatNumber            String?
  siret                String?
  steuernummer         String?
  bceNumber            String?
  companyName          String?
  companyAddress       String?
  logoUrl              String?
  logoKey              String?
  hourlyRate           Decimal?    @db.Decimal(10, 2)
  iban                 String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  proTrialUsed         Boolean     @default(false)
  maxTeamMembers       Int         @default(0)
  industry             String?
  setupComplete        Boolean     @default(false)
  accounts             Account[]
  projects             Project[]
  sessions             Session[]
  ownedTeam            Team?              @relation("TeamOwner")
  teamMember           TeamMember?
  assignments          ProjectAssignment[]
  photosCreated        Photo[]            @relation("PhotoCreator")
  timeEntriesCreated   TimeEntry[]        @relation("TimeEntryCreator")
  materialsCreated     Material[]         @relation("MaterialCreator")
  invoicesCreated      Invoice[]          @relation("InvoiceCreator")
  notesCreated         ProjectNote[]      @relation("NoteCreator")
  tags                 Tag[]              @relation("UserTags")
  tasksCreated         Task[]             @relation("TaskCreator")
  tasksAssigned        Task[]             @relation("TaskAssignee")
  notifications        Notification[]
  messages             Message[]          @relation("MessageAuthor")
  templates            ProjectTemplate[]  @relation("UserTemplates")
  safetyChecklists     SafetyChecklist[]  @relation("ChecklistSigner")
}

model Team {
  id          String           @id @default(cuid())
  name        String
  ownerId     String           @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  owner       User             @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  invitations TeamInvitation[]
  members     TeamMember[]

  @@index([ownerId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String   @unique
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model TeamInvitation {
  id         String    @id @default(cuid())
  teamId     String
  email      String
  role       TeamRole  @default(MEMBER)
  token      String    @unique @default(uuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, email])
  @@index([teamId])
  @@index([token])
}

model Project {
  id                 String               @id @default(cuid())
  name               String
  address            String
  status             ProjectStatus        @default(ACTIVE)
  clientName         String
  clientPhone        String?
  clientEmail        String?
  clientLocale       String?
  description        String?
  startDate          DateTime?
  endDate            DateTime?
  shareToken         String               @unique @default(uuid())
  shareExpiresAt     DateTime?
  artisanId          String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  clientLastViewedAt DateTime?
  budget             Int?
  progress           Int                  @default(0)
  nextSteps          Json?
  assignments        ProjectAssignment[]
  clientActions      ClientAction[]
  invoices           Invoice[]
  materials          Material[]
  photos             Photo[]
  artisan            User                 @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  timeEntries        TimeEntry[]
  notes              ProjectNote[]
  tags               ProjectTag[]
  tasks              Task[]
  messages           Message[]
  safetyChecklists   SafetyChecklist[]

  @@index([artisanId])
  @@index([shareToken])
}

model ProjectAssignment {
  id         String   @id @default(cuid())
  projectId  String
  userId     String
  assignedAt DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

model Photo {
  id          String     @id @default(cuid())
  projectId   String
  url         String
  key         String     @unique
  note        String?
  lat         Float?
  lng         Float?
  takenAt     DateTime   @default(now())
  order       Int        @default(0)
  createdById String?
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User?      @relation("PhotoCreator", fields: [createdById], references: [id], onDelete: SetNull)
  photoTags   PhotoTag[]

  @@index([projectId])
  @@index([createdById])
}

model TimeEntry {
  id          String   @id @default(cuid())
  projectId   String
  date        DateTime @db.Date
  hours       Decimal  @db.Decimal(4, 2)
  description String?
  createdById String?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation("TimeEntryCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([createdById])
}

model Material {
  id          String  @id @default(cuid())
  projectId   String
  label       String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(10, 2)
  unit        String  @default("u")
  createdById String?
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User?   @relation("MaterialCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([createdById])
}

model Invoice {
  id              String        @id @default(cuid())
  projectId       String
  number          String        @unique
  type            InvoiceType
  status          InvoiceStatus @default(DRAFT)
  lines           Json
  totalHT         Int
  totalTVA        Int
  totalTTC        Int
  currency        String        @default("EUR")
  locale          String        @default("fr-FR")
  invoiceFormat   InvoiceFormat @default(STANDARD_PDF)
  issuedAt        DateTime?
  dueAt           DateTime?
  paidAt          DateTime?
  facturXPath     String?
  remindersSentAt DateTime[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdById     String?
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy       User?         @relation("InvoiceCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, status])
  @@index([createdById])
}

model ClientAction {
  id        String           @id @default(cuid())
  projectId String
  type      ClientActionType
  payload   Json?
  createdAt DateTime         @default(now())
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectNote {
  id          String   @id @default(cuid())
  projectId   String
  content     String   @db.Text
  isPinned    Boolean  @default(false)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation("NoteCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([createdById])
}

model Tag {
  id          String       @id @default(cuid())
  name        String
  color       String       @default("#6366f1")
  artisanId   String
  createdAt   DateTime     @default(now())
  artisan     User         @relation("UserTags", fields: [artisanId], references: [id], onDelete: Cascade)
  projectTags ProjectTag[]
  photoTags   PhotoTag[]

  @@unique([artisanId, name])
  @@index([artisanId])
}

model ProjectTag {
  projectId String
  tagId     String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
}

model PhotoTag {
  photoId String
  tagId   String
  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([photoId, tagId])
}

model Task {
  id          String     @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Int        @default(0)
  dueDate     DateTime?
  assigneeId  String?
  createdById String?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy   User?      @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([assigneeId])
  @@index([createdById])
  @@index([status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model Message {
  id           String   @id @default(cuid())
  projectId    String
  content      String   @db.Text
  authorId     String?
  authorName   String?
  photoUrl     String?
  isFromClient Boolean  @default(false)
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author       User?    @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([authorId])
  @@index([projectId, createdAt])
}

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  tasks       Json     // [{ title, priority, order }]
  materials   Json     // [{ label, quantity, unitPrice, unit }]
  tags        String[]
  artisanId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  artisan     User     @relation("UserTemplates", fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([artisanId])
}

model SafetyChecklist {
  id          String    @id @default(cuid())
  projectId   String
  template    String    // "EPI", "ECHAFAUDAGE", "ELECTRIQUE", "AMIANTE"
  items       Json      // [{ id, label, checked, checkedAt, checkedBy }]
  signedAt    DateTime?
  signedById  String?
  signatureUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  signedBy    User?     @relation("ChecklistSigner", fields: [signedById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([signedById])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum NotificationType {
  CLIENT_COMMENT
  CLIENT_SIGNATURE
  TASK_ASSIGNED
  TASK_OVERDUE
  INVOICE_PAID
  TEAM_MEMBER_JOINED
  PHOTO_ADDED
  NOTE_ADDED
}

enum Plan {
  FREE
  PRO
  PRO_EQUIPE
  PRO_PLUS
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  DONE
  ARCHIVED
}

enum InvoiceType {
  QUOTE
  INVOICE
}

enum InvoiceStatus {
  DRAFT
  SENT
  ACCEPTED
  REFUSED
  PAID
  OVERDUE
}

/// Electronic invoicing format per country
enum InvoiceFormat {
  STANDARD_PDF
  FACTURX
  ZUGFERD
  PEPPOL
  FACTURAE
}

enum ClientActionType {
  STEP_VALIDATED
  COMMENT
  SIGNATURE
}

/// VAT scheme per country/status
enum VatScheme {
  STANDARD
  REDUCED
  MICRO_ENTREPRENEUR
  EXEMPT
  REVERSE_CHARGE
}
